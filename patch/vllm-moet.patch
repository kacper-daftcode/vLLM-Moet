+class SkinnyCubitFp8BlockScaledMMKernel(TritonFp8BlockScaledMMKernel):
+    """Triton block-scaled kernel with a cubit SASS fast path for decode-shaped
+    GEMMs (M <= 4): hand-scheduled skinny_fp8_mm at 68% DRAM roofline vs
+    Triton's ~62%, with UE8M0 scaling end-to-end. Opt-in via
+    VLLM_W8A8_SKINNY_CUBIT=1 (SM120 + cubins required, see skinny_fp8_cubit).
+
+    Activations are quantized with use_ue8m0=True and weights requantized to
+    power-of-two block scales (the documented DeepGEMM flow) so both the SASS
+    path (E8M0 scale bytes in QMMA.SF) and the Triton fallback see EXACTLY the
+    same quantized operands -> numerics differ only by GEMM accumulation
+    order, and prefill/decode stay mutually consistent.
+    """
+
+    @classmethod
+    def is_supported(cls, compute_capability=None):
+        from vllm.model_executor.layers.quantization.utils import (
+            skinny_fp8_cubit,
+        )
+
+        ok, why = super().is_supported(compute_capability)
+        if not ok:
+            return ok, why
+        if not skinny_fp8_cubit.enabled():
+            return False, "VLLM_W8A8_SKINNY_CUBIT not enabled / no cubins."
+        return True, None
+
+    def process_weights_after_loading(self, layer: torch.nn.Module) -> None:
+        super().process_weights_after_loading(layer)
+        from vllm.model_executor.layers.quantization.utils import (
+            skinny_fp8_cubit,
+        )
+
+        params = self._get_layer_params(layer)
+        weight_scale = (
+            params.weight_scale
+            if params.weight_scale_inv is None
+            else params.weight_scale_inv
+        )
+        # FOLD mode: the kernel folds the EXACT f32 scales per kb128 — no
+        # ue8m0 requant of anything, numerics identical to the Triton path.
+        # Only build the fragment-major copy (dual-residency) for allowed K.
+        if (
+            params.weight.shape[-1] % 64 == 0
+            and skinny_fp8_cubit.supported_k(params.weight.shape[-1])
+            and skinny_fp8_cubit.repack_allowed(params.weight.shape[-1])
+        ):
+            # EAGER: the hot path (under CUDA-graph capture) must only do
+            # dict lookups, never the permute itself.
+            skinny_fp8_cubit.weight_fragment_major(params.weight)
+            skinny_fp8_cubit.weight_scale_f32(weight_scale)
+
+    def apply_block_scaled_mm(
+        self,
+        A: torch.Tensor,
+        B: torch.Tensor,
+        As: torch.Tensor,
+        Bs: torch.Tensor,
+    ) -> torch.Tensor:
+        # single custom op: the skinny-vs-Triton choice happens INSIDE the op
+        # (shape-dependent), keeping the dynamo graph free of M guards.
+        return torch.ops.vllm.w8a8_skinny_or_triton_mm_func(
+            A,
+            B,
+            As,
+            Bs,
+            list(self.weight_group_shape),
+            self.config.out_dtype,
+        )
+
+
+def _w8a8_skinny_or_triton_mm_func(
+    qx: torch.Tensor,
+    weight: torch.Tensor,
+    x_scale: torch.Tensor,
+    weight_scale: torch.Tensor,
+    block_size: list[int],
+    output_dtype: torch.dtype,
+) -> torch.Tensor:
+    from vllm.model_executor.layers.quantization.utils import skinny_fp8_cubit
+
+    if skinny_fp8_cubit._DEBUG:
+        key = (qx.shape[0], weight.shape[0], qx.shape[-1], "dispatch")
+        if key not in skinny_fp8_cubit._miss_shapes:
+            skinny_fp8_cubit._miss_shapes.add(key)
+            skinny_fp8_cubit.logger.info(
+                "w8a8 dispatch M=%d N=%d K=%d -> %s", qx.shape[0],
+                weight.shape[0], qx.shape[-1],
+                "skinny-eligible" if qx.shape[0] <= skinny_fp8_cubit._MAX_M
+                and skinny_fp8_cubit.supported_k(qx.shape[-1]) else "TRITON")
+    if (
+        qx.shape[0] <= skinny_fp8_cubit._MAX_M
+        and skinny_fp8_cubit.supported_k(qx.shape[-1])
+    ):
+        b_packed = skinny_fp8_cubit.weight_fragment_major(weight)
+        if b_packed is not None:
+            bs_f32 = skinny_fp8_cubit.weight_scale_f32(weight_scale)
+            out = skinny_fp8_cubit.skinny_mm(qx, x_scale, b_packed, bs_f32)
+            if out is not None:
+                if out.dtype != output_dtype:
+                    out = out.to(output_dtype)
+                return out
+    return _w8a8_triton_block_scaled_mm_func(
+        qx, weight, x_scale, weight_scale, block_size, output_dtype
+    )
+
+
+def _w8a8_skinny_or_triton_mm_fake(
+    qx: torch.Tensor,
+    weight: torch.Tensor,
+    x_scale: torch.Tensor,
+    weight_scale: torch.Tensor,
+    block_size: list[int],
+    output_dtype: torch.dtype,
+) -> torch.Tensor:
+    return torch.empty(
+        (qx.size(0), weight.size(0)), dtype=output_dtype, device=qx.device
+    )
+
+
 # TODO we should be able to change the type of block_size to GroupShape
 # after we resolve GroupShape compilation issue
 # https://github.com/vllm-project/vllm/issues/25270
@@ -218,3 +337,9 @@ direct_register_custom_op(
     _w8a8_triton_block_scaled_mm_func,
