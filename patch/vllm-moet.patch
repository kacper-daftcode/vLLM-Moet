+    def _init_registered_buffers(self, expert_weights: Sequence[torch.Tensor]) -> None:
+        total_max_bytes = 0
+        for dtype in self._dtypes:
+            max_numel = max(
+                sum(t.numel() for t in expert_weights if t.dtype == dtype), 1
