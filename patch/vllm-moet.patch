+            )
+            cache_block_ptr = (
+                k_cache_ptr + physical_block.to(tl.int64) * block_stride
+            )
+            token_data_ptr = cache_block_ptr + pos_in_block * token_data_size
+            token_scale_ptr = (
+                cache_block_ptr
+                + cache_block_size * token_data_size
+                + pos_in_block * scale_dim
