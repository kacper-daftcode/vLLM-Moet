+def _fp8_lmhead_mode() -> str:
+    # "off" | "draft" (only heads marked _fp8_lmhead, e.g. MTP draft) | "all"
+    v = os.getenv("VLLM_FP8_LMHEAD", "0").lower()
+    if v == "all":
+        return "all"
+    return "draft" if v in ("1", "true", "yes", "on", "draft") else "off"
+
+
+def _fp8_lmhead_on() -> bool:
+    return _fp8_lmhead_mode() != "off"
+
+
+def _maybe_quant_lmhead_weight(lm_head) -> bool:
+    """Lazily quantize lm_head.weight (bf16) -> e4m3 + per-row scale, cached on
+    the module. Skips while a CUDA graph is capturing (alloc/cast not graph
+    safe); the eager sampler path quantizes on its first call. Returns True
+    when an fp8 weight is available."""
