@@ -0,0 +1,56 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""One-shot MLA latent capture for the TurboQuant probe (Phase 0.5).
+
+Env VLLM_LATENT_DUMP=/dir enables it: the first ~64k cached-latent rows
+(pre-quantization bf16 [*, 512] passed to quantize_and_insert_k_cache) and
+~4k decode-query rows are accumulated on GPU and written once as
+{dir}/latents_c.pt / latents_q.pt, then capture self-disables. Skips while
+a CUDA graph is being captured (allocations are illegal there); zero cost
+after completion.
+"""
+
+import os
+
+import torch
+
+_DIR = os.getenv("VLLM_LATENT_DUMP", "")
+_MAX_C = int(os.getenv("VLLM_LATENT_DUMP_C", "65536"))
+_MAX_Q = int(os.getenv("VLLM_LATENT_DUMP_Q", "4096"))
+
+_c: list = []
+_q: list = []
+_nc = 0
+_nq = 0
+_done_c = not _DIR
+_done_q = not _DIR
+
+
+def _flush(parts, path):
+    t = torch.cat([p.float().cpu() for p in parts])
+    torch.save(t, path)
+
+
+def maybe_dump_c(k: torch.Tensor) -> None:
+    global _nc, _done_c
+    if _done_c or torch.cuda.is_current_stream_capturing():
+        return
+    _c.append(k.detach()[:, :512].clone())
+    _nc += k.shape[0]
+    if _nc >= _MAX_C:
+        _done_c = True
+        _flush(_c, os.path.join(_DIR, "latents_c.pt"))
+        _c.clear()
+
+
+def maybe_dump_q(q: torch.Tensor) -> None:
+    global _nq, _done_q
+    if _done_q or torch.cuda.is_current_stream_capturing():
+        return
+    rows = q.detach().reshape(-1, q.shape[-1])[:, :512].clone()
+    _q.append(rows)
+    _nq += rows.shape[0]
+    if _nq >= _MAX_Q:
+        _done_q = True
+        _flush(_q, os.path.join(_DIR, "latents_q.pt"))
+        _q.clear()
