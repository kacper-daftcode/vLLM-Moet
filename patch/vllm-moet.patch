+    scale = (amax / _FP8_E4M3_MAX).float()  # [N,1]
+    lm_head._fp8_w = (w.detach() / scale).to(torch.float8_e4m3fn).contiguous()
+    lm_head._fp8_ws = scale.reshape(1, -1).contiguous()  # [1,N]
