+# bytes) ~halves it. Per-output-channel weight scale + per-token act scale,
+# torch._scaled_mm rowwise. Covers BOTH the target lm_head and the MTP draft
+# head (both flow through this layer). Quality-gated (acceptance + output).
+_FP8_E4M3_MAX = 448.0
+
