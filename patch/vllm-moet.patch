+            ((query_chunk_size, self.num_heads), torch.float32),
+            ((query_chunk_size, self.num_heads), torch.float32),
+            ((query_chunk_size, self.num_heads, q.shape[-1]), torch.float32),
+            ((query_chunk_size, self.num_heads), torch.float32),
+            ((query_chunk_size, self.num_heads), torch.float32),
