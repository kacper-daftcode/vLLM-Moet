+            torch.add(positions, offsets) if offsets is not None else positions,
+            query,
+            key,
+            head_size,
+            self.cos_sin_cache,
+            self.is_neox_style,
+            rope_dim_offset=rope_dim_offset,
+            inverse=inverse,
+        )
