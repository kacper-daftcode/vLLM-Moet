+                            (size_t)entry_idx * D_ROPE_C * sizeof(bf16) +
+                            KV::ROPE_SMEM_LANDING_OFF,
+                        data_base + KV_ROPE_OFFSET, V2_BULK_ROPE_BYTES, sm.mbar_full(buf));""",
+)
+patch(
+    DEC,
+    """    uint8_t* sm_kv_fp8 = sm.kv_fp8(buf);
+    bf16* sm_kv_rope = sm.kv_rope(buf);
+
