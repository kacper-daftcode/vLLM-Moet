+                a1_base.data_ptr(), ws["as1"].data_ptr(),
+                ws["c13"].data_ptr(),
+                a2_base.data_ptr(), ws["as2"].data_ptr(), ws["c2"].data_ptr(),
+                st["planes13"].data_ptr(), st["sc13"].data_ptr(),
+                st["planes2"].data_ptr(), st["sc2"].data_ptr(), pool_ptr,
