+        if self._rederive_ct < self.REDERIVE_DRAFTS:
+            return None
+        self._rederive_ct = 0
+        for j in range(gamma):
+            if obs[j] >= self.MIN_POSITION_OBS:
+                self._survival[j] = acc[j] / obs[j]
+            # Decay so the estimate keeps tracking workload drift.
