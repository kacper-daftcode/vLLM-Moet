# vLLM-Moet — DeepSeek-V4-Flash on SM120 (Blackwell), self-contained.
# Clones official vLLM at the pinned tag, applies our patch, builds for sm_120,
# and BAKES IN the prebuilt SM120 cubins — so running needs no cubit, no patch
# step, and no external cubin mount. Build from the repo root:
#   DOCKER_BUILDKIT=1 docker build -f Dockerfile.sm120 -t vllm-moet-sm120:base .
# (lower MAX_JOBS on a small host: --build-arg MAX_JOBS=8)
FROM nvidia/cuda:13.0.2-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y \
    python3 python3-dev python3-venv python3-pip \
    git wget cmake ninja-build curl \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir --break-system-packages \
    torch==2.11.0 tilelang setuptools-scm \
    'setuptools>=77.0.3,<81.0.0' ninja packaging wheel jinja2

# --- official vLLM @ pinned tag + our patch (no manual clone/apply needed) ---
ARG VLLM_REF=v0.19.2rc0
RUN git clone https://github.com/vllm-project/vllm.git /build/vllm \
    && cd /build/vllm && git checkout ${VLLM_REF}
COPY patch/vllm-moet.patch /tmp/vllm-moet.patch
RUN cd /build/vllm && git apply /tmp/vllm-moet.patch

WORKDIR /build/vllm
ARG MAX_JOBS=128
ENV TORCH_CUDA_ARCH_LIST="12.0" \
    MAX_JOBS=${MAX_JOBS} \
    SETUPTOOLS_SCM_PRETEND_VERSION=0.21.0.dev1 \
    CUDA_HOME=/usr/local/cuda
RUN pip install --break-system-packages -e . --no-build-isolation 2>&1 | tee /build/install.log | tail -50

# --- bake the prebuilt SM120 cubins so running needs no cubit / external mount ---
COPY kernels/cubins-sm120 /opt/vllm-moet/cubins
ENV VLLM_MOE_W2_CUBIT_DIR=/opt/vllm-moet/cubins \
    VLLM_SPARSE_MLA_PREFILL_CUBIN=/opt/vllm-moet/cubins/mla_prefill_state.cubin

ENTRYPOINT ["python3", "-m", "vllm.entrypoints.openai.api_server"]
